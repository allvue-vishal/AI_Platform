# AutoDoc Agent — Environment Configuration
# Copy this file to .env and fill in your values.

# ---- LLM Provider ----
# Supported: "litellm_proxy", "ollama", "vllm", "openai", "azure"
LLM_PROVIDER=litellm_proxy

# LiteLLM Proxy (recommended for enterprise)
# Point to your LiteLLM Proxy instance. The proxy handles model routing.
LLM_BASE_URL=http://your-litellm-proxy:4000
LLM_API_KEY=sk-your-litellm-proxy-key
LLM_MODEL=gpt-4o

# Ollama example:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=dummy
# LLM_MODEL=qwen3:72b

# vLLM example:
# LLM_PROVIDER=vllm
# LLM_BASE_URL=http://gpu-server:8000/v1
# LLM_API_KEY=dummy
# LLM_MODEL=Qwen/Qwen3-72B-Instruct

# Token budgets
MAX_TOKENS_PER_MODULE=100000
MAX_TOKENS_PER_LEAF=50000
MAX_DEPTH=2

# Output
OUTPUT_DIR=./docs-output
