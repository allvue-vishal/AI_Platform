# ── LiteLLM (required) ────────────────────────────────────
LITELLM_API_KEY=sk-your-api-key-here
# Optional: LiteLLM proxy or custom API base URL
LITELLM_API_BASE=
# Model identifier — any model LiteLLM supports
# Examples: anthropic/claude-sonnet-4-20250514, openai/gpt-4o
LITELLM_MODEL=anthropic/claude-sonnet-4-20250514

# ── Email (required for sending) ─────────────────────────
# Gmail API uses OAuth (credentials.json + token.json), not SMTP.
# First run opens a browser to authorize; token.json is created automatically.
RECIPIENT_EMAIL=your.email@gmail.com

# ── Reddit API (optional, not currently used) ────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
